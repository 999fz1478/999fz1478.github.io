#comments
  background: rgba(255, 252, 248, 0.92)
  box-shadow: 0 18px 45px rgba(23, 50, 59, 0.08)
  padding: article-padding
  border: 1px solid rgba(23, 50, 59, 0.08)
  border-radius: 24px
  margin: block-margin auto
  max-width: 900px
  a
    color: color-link

.comments-heading
  margin-bottom: 18px
  h3
    font-family: font-serif
    font-size: 1.6em
    margin: 0 0 8px
  p
    margin: 0
    color: color-grey

.comments-setup-note
  padding: 18px 20px
  background: rgba(15, 118, 110, 0.06)
  border: 1px dashed rgba(15, 118, 110, 0.28)
  border-radius: 16px
  color: color-grey
  line-height: 1.8
