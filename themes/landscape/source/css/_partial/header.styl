#header
  height: banner-height
  position: relative
  border-bottom: none
  &:before, &:after
    content: ""
    position: absolute
    left: 0
    right: 0
    height: 100%
  &:before
    top: 0
    background: linear-gradient(135deg, rgba(9, 35, 40, 0.88), rgba(15, 118, 110, 0.52))
  &:after
    bottom: 0
    background: linear-gradient(180deg, transparent 45%, rgba(245, 239, 229, 0.95))

#header-outer
  height: 100%
  position: relative

#header-inner
  position: relative
  overflow: hidden

#banner
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  background: url(banner-url) center #0d262c
  background-size: cover
  z-index: -1
  transform: scale(1.02)

#header-title
  text-align: center
  height: logo-size
  position: absolute
  top: 50%
  left: 0
  width: 100%
  margin-top: logo-size * -0.6

$logo-text
  text-decoration: none
  color: #fff
  font-weight: 700
  text-shadow: 0 12px 28px rgba(0, 0, 0, 0.28)

#logo
  @extend $logo-text
  font-size: logo-size
  line-height: logo-size
  letter-spacing: 0.08em

#subtitle
  @extend $logo-text
  display: inline-block
  font-size: subtitle-size
  line-height: 1.6
  letter-spacing: 0.04em
  max-width: 720px
  padding: 10px 18px
  border-radius: 999px
  background: rgba(255, 255, 255, 0.12)
  backdrop-filter: blur(10px)

#subtitle-wrap
  margin-top: 18px

#main-nav
  float: left
  margin-left: 0
  background: rgba(255, 255, 255, 0.1)
  border: 1px solid rgba(255, 255, 255, 0.16)
  border-radius: 999px
  backdrop-filter: blur(10px)
  padding: 4px 10px

$nav-link
  float: left
  color: #fff
  opacity: 0.88
  text-decoration: none
  text-shadow: none
  transition: opacity 0.2s, background 0.2s, transform 0.2s
  display: block
  padding: 14px 16px
  &:hover
    opacity: 1
    background: rgba(255, 255, 255, 0.12)
    transform: translateY(-1px)

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 14px 16px
  position: relative
  cursor: pointer

.main-nav-link
  @extend $nav-link
  font-weight: 700
  letter-spacing: 0.04em
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#sub-nav
  float: right
  margin-right: 0
  background: rgba(255, 255, 255, 0.1)
  border: 1px solid rgba(255, 255, 255, 0.16)
  border-radius: 999px
  backdrop-filter: blur(10px)
  padding: 4px 10px

#search-form-wrap
  position: absolute
  top: 12px
  width: 190px
  height: 36px
  right: -190px
  opacity: 0
  transition: 0.2s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: #fff
  padding: 8px 16px
  border-radius: 999px
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.16)

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: #bbb
  cursor: pointer
  &:hover, &:focus
    color: #777
