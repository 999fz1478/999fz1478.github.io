.article
  margin: block-margin 0

.article-inner
  @extend $block
  overflow: hidden

.article-meta
  clearfix()
  display: flex
  align-items: center
  gap: 10px
  padding: 22px article-padding 0
  flex-wrap: wrap

.article-date
  @extend $block-caption
  float: none
  margin-bottom: 0
  padding: 8px 12px
  border-radius: 999px
  background: rgba(15, 118, 110, 0.08)
  color: color-link

.article-category
  float: none
  line-height: 1em
  color: color-grey
  text-shadow: none
  margin-left: 0

.article-category-link
  @extend $block-caption
  margin: 0
  padding: 8px 12px
  border-radius: 999px
  background: rgba(191, 90, 36, 0.08)
  color: #b65423

.article-header
  padding: 18px article-padding 0

.article-title
  text-decoration: none
  font-size: 2.3em
  font-weight: 800
  color: color-default
  line-height: line-height-title
  transition: color 0.2s
  font-family: font-serif
  a&:hover
    color: color-link

.article-lead
  margin: 18px 0 0
  font-size: 1.02em
  line-height: 1.9
  color: color-grey

.article-entry
  @extend $base-style
  clearfix()
  color: color-default
  padding: 0 article-padding article-padding
  font-size: 1.05em
  p, table
    line-height: line-height
    margin: line-height 0
  h1, h2, h3, h4, h5, h6
    font-weight: bold
    font-family: font-serif
  h1, h2, h3, h4, h5, h6
    line-height: line-height-title
    margin: line-height-title 0
  h2
    padding-top: 0.2em
    border-top: 1px solid rgba(23, 50, 59, 0.08)
  a
    color: color-link
    text-decoration: none
    &:hover
      text-decoration: underline
  ul, ol, dl
    margin-top: line-height
    margin-bottom: line-height
  img, video
    max-width: 100%
    height: auto
    display: block
    margin: auto
  iframe
    border: none
  table
    width: 100%
    border-collapse: collapse
    border-spacing: 0
  th
    font-weight: bold
    border-bottom: 3px solid color-border
    padding-bottom: 0.5em
  td
    border-bottom: 1px solid color-border
    padding: 10px 0
  blockquote
    font-family: font-serif
    margin: line-height 0
    padding: 18px 22px
    text-align: left
    border-left: 4px solid rgba(15, 118, 110, 0.28)
    background: rgba(15, 118, 110, 0.05)
    border-radius: 18px
    footer
      font-size: font-size
      margin: line-height 0
      font-family: font-sans
      cite
        &:before
          content: "-"
          padding: 0 0.5em
  .pullquote
    text-align: left
    width: 45%
    margin: 0
    &.left
      margin-left: 0.5em
      margin-right: 1em
    &.right
      margin-right: 0.5em
      margin-left: 1em
  .caption
    color: color-grey
    display: block
    font-size: 0.9em
    margin-top: 0.5em
    position: relative
    text-align: center
  .video-container
    position: relative
    padding-top: (9 / 16 * 100)%
    height: 0
    overflow: hidden
    iframe, object, embed
      position: absolute
      top: 0
      left: 0
      width: 100%
      height: 100%
      margin-top: 0

.article-more-link a
  display: inline-block
  line-height: 1em
  padding: 11px 16px
  border-radius: 999px
  background: rgba(15, 118, 110, 0.08)
  color: color-link
  text-shadow: none
  text-decoration: none
  &:hover
    background: color-link
    color: #fff
    text-decoration: none
    text-shadow: none

.article-footer
  clearfix()
  font-size: 0.85em
  line-height: line-height
  border-top: 1px solid rgba(23, 50, 59, 0.08)
  padding-top: 18px
  margin: 0 article-padding article-padding
  a
    color: color-grey
    text-decoration: none
    &:hover
      color: color-default

.article-tag-list-item
  float: left
  margin-right: 10px
  margin-bottom: 10px

.article-tag-list-link
  display: inline-block
  padding: 8px 12px
  border-radius: 999px
  background: rgba(23, 50, 59, 0.05)
  &:before
    content: "#"

.article-comment-link
  float: right
  &:before
    padding-right: 8px

.article-share-link
  cursor: pointer
  float: right
  margin-left: 20px
  &:before
    padding-right: 6px

#article-nav
  clearfix()
  position: relative
  @media mq-normal
    margin: block-margin 0
    &:before
      absolute-center(8px)
      content: ""
      border-radius: 50%
      background: color-border

.article-nav-link-wrap
  text-decoration: none
  text-shadow: none
  color: color-grey
  box-sizing: border-box
  margin-top: block-margin
  text-align: center
  display: block
  &:hover
    color: color-default
  @media mq-normal
    width: 50%
    margin-top: 0

#article-nav-newer
  @media mq-normal
    float: left
    text-align: right
    padding-right: 20px

#article-nav-older
  @media mq-normal
    float: right
    text-align: left
    padding-left: 20px

.article-nav-caption
  text-transform: uppercase
  letter-spacing: 0.18em
  color: color-border
  line-height: 1em
  font-weight: bold
  #article-nav-newer &
    margin-right: -2px

.article-nav-title
  font-size: 0.85em
  line-height: line-height
  margin-top: 0.5em

.article-share-box
  position: absolute
  display: none
  background: #fff
  box-shadow: 0 20px 40px rgba(23, 50, 59, 0.18)
  border-radius: 18px
  margin-left: -145px
  overflow: hidden
  z-index: 1
  &.on
    display: block

.article-share-input
  width: 100%
  background: none
  box-sizing: border-box
  font: 14px font-sans
  padding: 0 15px
  color: color-default
  outline: none
  border: 1px solid rgba(23, 50, 59, 0.08)
  border-radius: 18px 18px 0 0
  height: 36px
  line-height: 36px

.article-share-links
  clearfix()
  background: color-background

$article-share-link
  width: 50px
  height: 36px
  display: block
  float: left
  position: relative
  color: #999
  text-shadow: none
  .fa
    font-size: 20px
    absolute-center(@font-size)
    text-align: center
  &:hover
    color: #fff

.article-share-twitter
  @extend $article-share-link
  &:hover
    background: color-twitter

.article-share-facebook
  @extend $article-share-link
  &:hover
    background: color-facebook

.article-share-pinterest
  @extend $article-share-link
  &:hover
    background: color-pinterest

.article-share-linkedin
  @extend $article-share-link
  &:hover
    background: color-linkedin

.article-gallery
  background: #000
  position: relative

.article-gallery-photos
  position: relative
  overflow: hidden

.article-gallery-img
  display: none
  max-width: 100%
  &:first-child
    display: block
  &.loaded
    position: absolute
    display: block
  img
    display: block
    max-width: 100%
    margin: 0 auto

.article--detail
  max-width: 900px
  margin-left: auto
  margin-right: auto

.article--index .article-title
  font-size: 1.85em

.article--index .article-entry
  font-size: 1em

.article--index .article-inner
  transition: transform 0.2s ease, box-shadow 0.2s ease

.article--index .article-inner:hover
  transform: translateY(-4px)
  box-shadow: 0 24px 48px rgba(23, 50, 59, 0.11)
