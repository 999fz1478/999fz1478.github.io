// Config
support-for-ie = false
vendor-prefixes = webkit moz ms official

// Colors
color-default = #17323b
color-grey = #6f7f84
color-border = #d7d0c2
color-link = #0f766e
color-background = #f5efe5
color-sidebar-text = #51656c
color-widget-background = rgba(255, 251, 245, 0.92)
color-widget-border = rgba(23, 50, 59, 0.08)
color-footer-background = #12343b
color-mobile-nav-background = #17323b
color-twitter = #00aced
color-facebook = #3b5998
color-pinterest = #cb2027
color-linkedin = #0077B5

// Fonts
font-sans = "Manrope", "Segoe UI", "PingFang SC", "Hiragino Sans GB",
    "Microsoft YaHei", sans-serif
font-serif = "Noto Serif SC", "Source Han Serif SC", Georgia, serif
font-mono = "Source Code Pro", Consolas, Monaco, Menlo, Consolas, monospace
font-icon = ForkAwesome
font-size = 15px
line-height = 1.8em
line-height-title = 1.2em

// Header
logo-size = 56px
subtitle-size = 18px
banner-height = 380px
banner-url = hexo-config("banner")

sidebar = hexo-config("sidebar")

// Layout
block-margin = 36px
article-padding = 32px
mobile-nav-width = 280px
main-column = 9
sidebar-column = 3

if sidebar and sidebar isnt bottom
  _sidebar-column = sidebar-column
else
  _sidebar-column = 0

// Grids
column-width = 84px
gutter-width = 24px
columns = main-column + _sidebar-column

// Media queries
mq-mobile = "screen and (max-width: 479px)"
mq-tablet = "screen and (min-width: 480px) and (max-width: 767px)"
mq-normal = "screen and (min-width: 768px)"
